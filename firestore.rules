service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Orders Collection Guard
    match /orders/{orderId} {
      // Admins can read/write orders that belong to them; customers can create orders or read their specific table's order
      allow create: if true; 
      allow read, update, delete: if request.auth != null && (resource.data.adminEmail == request.auth.token.email || resource.data.adminId == request.auth.uid);
    }
    
    // Administrative Configuration Layouts (Menu, Categories, Receipt Studio, Tables)
    match /menu/{itemId} {
      allow read: if true; // Publicly readable by scanning customers
      allow write: if request.auth != null && (accountMatchesOwner());
    }
    
    match /categories/{catId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /tables/{tableId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /sales/{saleId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.adminEmail == request.auth.token.email);
    }

    // Helper reusable validation function
    function accountMatchesOwner() {
      return request.resource.data.adminEmail == request.auth.token.email || request.resource.data.adminId == request.auth.uid;
    }
  }
}
